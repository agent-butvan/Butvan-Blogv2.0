# ============================================================================
# Butvan Blog 2.0 - 环境变量模版 (.env.example)
# 使用说明: 复制本文件为 .env 并填入你本地真实的敏感密码配置
# 本文件同时服务于：
#   1. Docker Compose（POSTGRES_DB、REDIS_PASSWORD 等容器初始化变量）
#   2. Spring Boot（启动类 BlogApplication 中在 main 方法执行前自动加载）
# ============================================================================

# ---------- 1. Docker Compose 容器初始化变量 ----------
POSTGRES_DB=butvan_blog
POSTGRES_USER=butvan
POSTGRES_PASSWORD=your_secure_postgres_password
REDIS_PASSWORD=your_secure_redis_password

# ---------- 2. Spring Boot 应用变量（与 YAML 中 ${} 占位符对应） ----------
# 数据库连接
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/butvan_blog
SPRING_DATASOURCE_USERNAME=butvan
SPRING_DATASOURCE_PASSWORD=your_secure_postgres_password

# Redis 连接
SPRING_DATA_REDIS_HOST=localhost
SPRING_DATA_REDIS_PORT=6379
SPRING_DATA_REDIS_PASSWORD=your_secure_redis_password

# 微信开发配置
WEIXIN_APPID=your_weixin_appid
WEIXIN_APPSECRET=your_weixin_appsecret

# 邮件发送配置
MAIL_HOST=smtp.qq.com
MAIL_PORT=587
MAIL_USERNAME=your_mail_username
MAIL_PASSWORD=your_mail_password

# 安全加密 JWT
JWT_SECRET=your_super_safe_jwt_secret_key_at_least_256_bits

# ---------- 3. MinIO 对象存储配置 ----------
# MinIO 自定义访问域名（配合反向代理 HTTPS 使用，解决 Mixed Content 问题）
STORAGE_MINIO_CUSTOM_DOMAIN=https://your-minio-domain.com
