# ============================================================================
# Butvan Blog 2.0 - 容器服务本地环境变量模版 (.env.example)
# 使用说明: 复制本文件为 .env 并填入你本地真实的敏感密码配置
# ============================================================================

# 1. 数据库 PostgreSQL 配置
POSTGRES_DB=butvan_blog
POSTGRES_USER=butvan
POSTGRES_PASSWORD=your_secure_postgres_password

# 2. 缓存 Redis 配置
REDIS_PASSWORD=your_secure_redis_password
